---
import '../styles/globals.css';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'rinha2-back-end-go | Less is More. Except Error Handling.',
  description = 'High-performance banking API for the Rinha de Backend challenge. Built with Go 1.25, chi/v5 router, and pgx/v5 connection pool. 221 lines under strict resource constraints (1.5 CPU, 550MB RAM).'
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://jonathanperis.github.io');
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const basePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const faviconHref = `${basePath}favicon.ico`;
const faviconSvgHref = `${basePath}favicon.svg`;
const faviconPngHref = `${basePath}favicon.png`;
const favicon32Href = `${basePath}favicon-32x32.png`;
const appleTouchIconHref = `${basePath}apple-touch-icon.png`;
const socialImageUrl = new URL(`${basePath}social-preview.png`, siteUrl).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  'name': 'Rinha de Backend — Go',
  'description': description,
  'url': pageUrl,
  'codeRepository': 'https://github.com/jonathanperis/rinha2-back-end-go',
  'programmingLanguage': 'Go',
  'runtimePlatform': 'Go 1.25',
  'license': 'https://github.com/jonathanperis/rinha2-back-end-go/blob/main/LICENSE',
  'author': {
    '@type': 'Person',
    'name': 'Jonathan Peris',
    'url': 'https://jonathanperis.github.io/'
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Go, Golang, chi, pgx, PostgreSQL, banking API, Rinha de Backend, performance, load testing" />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#00ADD8" />
    <link rel="icon" href={faviconHref} sizes="any" />
    <link rel="icon" href={faviconSvgHref} type="image/svg+xml" />
    <link rel="icon" href={faviconPngHref} type="image/png" />
    <link rel="icon" href={favicon32Href} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={appleTouchIconHref} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="rinha2-back-end-go" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="rinha2-back-end-go dark teal benchmark dashboard social preview" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content="rinha2-back-end-go dark teal benchmark dashboard social preview" />
    <meta name="twitter:creator" content="@jperis_silva" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>
    <Analytics />
  </head>
  <body>
    <slot />
  </body>
</html>
